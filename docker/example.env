# Default PostgreSQL database when using docker/docker-compose.yml.
POSTGRES_USER=ai_news
POSTGRES_PASSWORD=ai_news_password
POSTGRES_DB=ai_news
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
GEMINI_API_KEY=your_gemini_api_key_here
GMAIL_ADDRESS=your_sender_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_CHECKOUT_MODE=subscription
STRIPE_PRICE_ID=
STRIPE_AMOUNT_CENTS=100
STRIPE_CURRENCY=usd
STRIPE_INTERVAL=month
STRIPE_PRODUCT_NAME=AI News Daily Email Plan

# Optional single-url override. If set, this takes priority over POSTGRES_* values.
# DATABASE_URL=postgresql+psycopg2://ai_news:ai_news_password@localhost:5432/ai_news

# Optional lightweight local SQLite fallback.
# DATABASE_URL=sqlite:///./data/ai_news.db
